# ============================================
# JOYSHIDDENBEAUTY — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/joyshiddenbeauty

# --- Security ---
SECRET_KEY=change-me-to-a-long-random-string-in-production
GOOGLE_CLIENT_ID=your_google_client_id_here

# --- OPay ---
OPAY_PUBLIC_KEY=OPAYPUB_your_public_key_here
OPAY_SECRET_KEY=OPAYSEC_your_secret_key_here
OPAY_MERCHANT_ID=256600000000000
OPAY_BASE_URL=https://sandboxapi.opaycheckout.com

# --- Email (Gmail SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=joyshiddenbeauty1@gmail.com
SMTP_PASSWORD=
FROM_EMAIL=joyshiddenbeauty1@gmail.com

# --- Sentry ---
SENTRY_DSN=

# --- App ---
APP_ENV=development
FRONTEND_URL=http://localhost:3000
