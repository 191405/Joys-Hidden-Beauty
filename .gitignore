# ==========================================
# JOYSHIDDENBEAUTY — Monorepo Git Ignore
# ==========================================

# --- System & OS Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- IDEs & Editors ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- JavaScript / Node.js (Frontend) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Python & FastAPI (Backend) ---
backend/__pycache__/
backend/.venv/
backend/venv/
backend/env/
backend/err.txt
backend/.pytest_cache/
*.pyc
*.pyo
*.pyd

# --- Databases (SQLite Local Files) ---
backend/*.db
backend/*.sqlite
*.db-journal
*.db-wal
*.db-shm

# --- Configuration & Environment Secrets ---
.env
.env.local
.env.production
.env.development
.env.test
backend/.env
frontend/.env.local
frontend/.env.production
frontend/.env.development
